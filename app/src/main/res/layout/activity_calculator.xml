<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:gravity="bottom"
    android:paddingBottom="24dp">

    <!-- Display area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/display"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:gravity="center_vertical|end"
            android:padding="20dp"
            android:text="0"
            android:textColor="#212121"
            android:textSize="36sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="start" />
    </LinearLayout>

    <!-- Keypad area -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="12dp"
        android:useDefaultMargins="true">

        <!-- Row 1 -->
        <Button android:id="@+id/btn7" android:text="7" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn8" android:text="8" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn9" android:text="9" android:layout_columnWeight="1" />
        <Button android:id="@+id/btnDiv" android:text="/" android:layout_columnWeight="1" android:backgroundTint="#FF9800" android:textColor="#FFF" />

        <!-- Row 2 -->
        <Button android:id="@+id/btn4" android:text="4" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn5" android:text="5" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn6" android:text="6" android:layout_columnWeight="1" />
        <Button android:id="@+id/btnMul" android:text="*" android:layout_columnWeight="1" android:backgroundTint="#FF9800" android:textColor="#FFF" />

        <!-- Row 3 -->
        <Button android:id="@+id/btn1" android:text="1" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn2" android:text="2" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn3" android:text="3" android:layout_columnWeight="1" />
        <Button android:id="@+id/btnSub" android:text="-" android:layout_columnWeight="1" android:backgroundTint="#FF9800" android:textColor="#FFF" />

        <!-- Row 4 -->
        <Button android:id="@+id/btn0" android:text="0" android:layout_columnWeight="1" />
        <Button android:id="@+id/btnClear" android:text="C" android:layout_columnWeight="1" android:backgroundTint="#F44336" android:textColor="#FFF" />
        <Button android:id="@+id/btnEquals" android:text="=" android:layout_columnWeight="1" android:backgroundTint="#4CAF50" android:textColor="#FFF" />
        <Button android:id="@+id/btnAdd" android:text="+" android:layout_columnWeight="1" android:backgroundTint="#FF9800" android:textColor="#FFF" />

        <!-- Row 5 -->
        <Button android:id="@+id/btnPow" android:text="num" android:layout_columnWeight="1" android:backgroundTint="#FF9800" android:textColor="#FFF" />

    </GridLayout>

</LinearLayout>
